# =============================================================================
# WIKIS-DFAED — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Fichiers de configuration des assistants IA
# Contiennent l'architecture interne, les conventions et des détails sensibles.
# -----------------------------------------------------------------------------
CLAUDE.md
AGENTS.md
GEMINI.md
.claude/

# -----------------------------------------------------------------------------
# MediaWiki — configuration serveur
# Contient : clé secrète ($wgSecretKey), mots de passe DB, sel de hash, etc.
# -----------------------------------------------------------------------------
LocalSettings.php

# -----------------------------------------------------------------------------
# Docker — configuration locale avec credentials
# Contient les mots de passe de la base de données et de l'admin.
# -----------------------------------------------------------------------------
docker-compose.yml
docker-compose.override.yml
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Secrets & certificats (format générique)
# -----------------------------------------------------------------------------
*.key
*.pem
*.p12
*.pfx
*.cer
*.crt
secrets/
credentials/
*secret*
*password*
*passwd*
*token*

# -----------------------------------------------------------------------------
# Bases de données locales
# -----------------------------------------------------------------------------
*.sql
*.sqlite
*.db

# -----------------------------------------------------------------------------
# Artefacts systèmes
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# -----------------------------------------------------------------------------
# Éditeurs & IDEs
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# Logs & temporaires
# -----------------------------------------------------------------------------
*.log
*.tmp
*.temp
/tmp/

# -----------------------------------------------------------------------------
# Cache files Apple system
# -----------------------------------------------------------------------------

._*
